# Virtualenv and Python caches
.venv/
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Local secrets and env files (config comes from runtime env vars)
.env
.env.*
!.env.example

# Tests and eval scripts — not needed to serve the API
tests/
eval/

# Processed chunks and index artifacts — built offline into named volumes at runtime
data/processed/
data/faiss_index/*
!data/faiss_index/.gitkeep
data/bm25_index/*
!data/bm25_index/.gitkeep
*.db

# Git and editor noise
.git/
.gitignore
*.md
