# --- LLM Provider (Gemini via langchain-google-genai) ---
GOOGLE_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0.0

# --- Auth ---
# Comma-separated "token:tier" pairs used for bearer-token auth (see app/core/security.py)
BACKEND_API_TOKENS=changeme-dev-token:standard

# --- Embeddings ---
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5

# --- Retrieval ---
ENABLE_RERANKER=false
RETRIEVAL_TOP_K=20
RERANK_TOP_N=5
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# --- Hybrid retrieval fusion weights (semantic vs. keyword leg, see PLAN.md Section 4) ---
HYBRID_SEMANTIC_WEIGHT=0.5
HYBRID_KEYWORD_WEIGHT=0.5

# --- Confidence thresholds (see PLAN.md Section 7) ---
CONFIDENCE_REFUSAL_THRESHOLD=0.4
CONFIDENCE_CAUTION_THRESHOLD=0.6

# --- Confidence score weights (retrieval_component vs. groundedness_component) ---
CONFIDENCE_RETRIEVAL_WEIGHT=0.5
CONFIDENCE_GROUNDEDNESS_WEIGHT=0.5

# --- Storage ---
SQLITE_DB_PATH=./data/app.db
FAISS_INDEX_DIR=./data/faiss_index
BM25_INDEX_DIR=./data/bm25_index

# --- Cache / rate limiting ---
REDIS_URL=redis://redis:6379/0
CACHE_TTL_SECONDS=3600
CACHE_SEMANTIC_SIMILARITY_THRESHOLD=0.95
CACHE_SEMANTIC_MAX_ENTRIES=100
RATE_LIMIT_PER_MINUTE=30
RATE_LIMIT_TIER_LIMITS=standard:30,premium:100

# --- Frontend -> backend proxy (read server-side only, never exposed to the client) ---
BACKEND_API_URL=http://backend:8000
BACKEND_API_TOKEN=changeme-dev-token
