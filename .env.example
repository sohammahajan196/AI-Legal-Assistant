# =============================================================================
# Docker Compose (TASKS.md T53) + hosted production env contract
# =============================================================================
# Copy this file to the repo root as `.env` before `docker compose up`:
#   cp .env.example .env
#
# Local uvicorn (from backend/) also loads this repo-root `.env` via absolute
# paths — a separate backend/.env copy is optional and overrides root values.
#
# Required for a working chat round trip:
#   - GOOGLE_API_KEY          Gemini API key (backend LLM calls)
#   - BACKEND_API_TOKENS      Bearer token(s) accepted by the backend API
#   - BACKEND_API_TOKEN       Same token value the frontend proxy sends (must match)
#   - BACKEND_API_URL         http://backend:8000 (set automatically in compose;
#                             keep this value when using docker compose;
#                             on Vercel set to the Render backend HTTPS URL)
#   - REDIS_URL               redis://localhost:6379/0 for local uvicorn;
#                             compose overrides to redis://redis:6379/0 at runtime;
#                             on Render set to the Upstash Redis URL
#
# Backend Docker image (Render / `docker compose build`):
#   - Embedding weights + FAISS/BM25 are baked at image build time.
#   - HF_HUB_OFFLINE / TRANSFORMERS_OFFLINE are set in the Dockerfile so
#     runtime never downloads models (Render free tier has no persistent disk).
#   - Optional local volume refresh after EMBEDDING_MODEL / corpus changes:
#       docker compose run --rm backend python scripts/ingest.py
#       docker compose run --rm backend python scripts/build_index.py
#       # recreate the faiss_index volume if it still holds an old index
#   docker compose up --build
#
# Named volumes (redis_data, faiss_index, sqlite_data) persist across
# `docker compose down` / `docker compose up` cycles.

# --- LLM Provider (Gemini via langchain-google-genai) ---
GOOGLE_API_KEY=your-gemini-api-key-here
# Free-tier quotas are per-model (RPM/RPD) and change over time — models get
# deprecated and limits shift. Periodically re-check Google AI Studio's
# rate-limit dashboard; do not assume this default stays available forever.
GEMINI_MODEL=gemini-3.5-flash
GEMINI_TEMPERATURE=0.0
# Retries on Gemini 503/UNAVAILABLE (exponential backoff: 1s, 2s, 4s, 8s + jitter).
# SDK built-in retries are disabled (max_retries=1); these settings control our layer.
GEMINI_MAX_RETRIES=4
GEMINI_RETRY_BASE_DELAY_SECONDS=1.0
# Optional fallback when the primary model is overloaded (leave blank to disable).
# GEMINI_FALLBACK_MODEL=gemini-2.5-flash

# --- Auth ---
# Comma-separated "token:tier" pairs used for bearer-token auth (see app/core/security.py)
BACKEND_API_TOKENS=changeme-dev-token:standard

# --- Embeddings ---
# Lightweight 384-d model baked into the backend Docker image at build time.
# Chosen over larger BGE models to stay under Render free-tier 512MB RAM
# (torch + FAISS + embeddings otherwise OOM). After changing this, rebuild the
# image (and recreate the faiss_index volume locally) so FAISS matches the
# new embedding space.
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- HuggingFace offline flags (set automatically in backend/Dockerfile) ---
# Documented here so operators know what the production image enables.
# Leave unset for local uvicorn so the first run can download model weights.
# HF_HUB_OFFLINE=1
# TRANSFORMERS_OFFLINE=1
# HF_DATASETS_OFFLINE=1
# Single worker only on free-tier hosts — do not raise this on Render 512MB.
# WEB_CONCURRENCY=1

# --- Retrieval ---
ENABLE_RERANKER=false
RETRIEVAL_TOP_K=20
RERANK_TOP_N=5
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# --- Hybrid retrieval fusion weights (semantic vs. keyword leg, see PLAN.md Section 4) ---
HYBRID_SEMANTIC_WEIGHT=0.5
HYBRID_KEYWORD_WEIGHT=0.5

# --- Confidence thresholds (see PLAN.md Section 7) ---
CONFIDENCE_REFUSAL_THRESHOLD=0.4
CONFIDENCE_CAUTION_THRESHOLD=0.6

# --- Confidence score weights (retrieval_component vs. groundedness_component) ---
CONFIDENCE_RETRIEVAL_WEIGHT=0.5
CONFIDENCE_GROUNDEDNESS_WEIGHT=0.5

# --- Storage ---
# Paths are relative to /app inside the backend container.
SQLITE_DB_PATH=./data/app.db
FAISS_INDEX_DIR=./data/faiss_index
BM25_INDEX_DIR=./data/bm25_index

# --- Cache / rate limiting ---
# Local uvicorn / redis-cli: use localhost. docker compose overrides this to
# redis://redis:6379/0 so the backend container talks to the redis service.
# Hosted (Render): set to your Upstash Redis URL (rediss://…).
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=3600
CACHE_SEMANTIC_SIMILARITY_THRESHOLD=0.95
CACHE_SEMANTIC_MAX_ENTRIES=100
RATE_LIMIT_PER_MINUTE=30
RATE_LIMIT_TIER_LIMITS=standard:30,premium:100

# --- Frontend -> backend proxy (read server-side only, never exposed to the client) ---
# Compose: http://backend:8000. Local Next.js: http://127.0.0.1:8000.
# Vercel: https://<your-render-service>.onrender.com
BACKEND_API_URL=http://backend:8000
BACKEND_API_TOKEN=changeme-dev-token
